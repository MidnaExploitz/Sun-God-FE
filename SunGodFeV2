--// TOGGLE CHARGE (unchanged)
local camShakeConn, charShakeConn

local function toggleCharge(hrp)
    if not hrp then return end
    local char     = hrp.Parent
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return end

    setupCharge(hrp)
    isCharging = not isCharging

    if isCharging then
        persistentSunColor = CFG.sunColor
        persistentLightColor = CFG.sunColor

        if sunOrb then
            tw(sunOrb, 0.4, { Color = persistentSunColor })
            local light = sunOrb:FindFirstChildWhichIsA("PointLight")
            if light then tw(light, 0.4, { Color = persistentLightColor, Brightness = 4.5 }) end
            if sunFire then
                sunFire.Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0,   Color3.fromRGB(255, 255, 80)),
                    ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255, 210, 60)),
                    ColorSequenceKeypoint.new(1,   Color3.fromRGB(255, 50,  0)),
                }
            end
        end

        originalWalkSpeed = humanoid.WalkSpeed
        originalAnchored  = hrp.Anchored
        chargeBaseCF      = hrp.CFrame

        chargePhase = 1
        fullPowerStartTime = tick()
        phase3StartTime = 0
        phase4StartTime = 0
        phase2RandomTriggerTime = 0

        updateSunGodTitle(chargePhase)

        playOnly(tracks.charge)

        chargeParticles.Enabled       = true
        ringParticles.Enabled         = true
        yellowRingParticles.Enabled   = true
        centralGlow.Enabled           = true
        for _, b in ipairs(lightningBeams) do if b.beam then b.beam.Enabled = true end end

        startFlicker()
        ringLoop(ringParticles, 1.8)
        ringLoop(yellowRingParticles, 1.4)
        chargeSoundLoop()

        local ti = TweenInfo.new(CFG.powerupTime, Enum.EasingStyle.Linear)
        tw(chargeSoundA, CFG.powerupTime, { Volume = 1 }, Enum.EasingStyle.Linear)
        tw(chargeSoundB, CFG.powerupTime, { Volume = 1 }, Enum.EasingStyle.Linear)
        TweenService:Create(chargeParticles, ti, { Rate = 1300 }):Play()
        TweenService:Create(centralGlow,     ti, { Rate = 12  }):Play()

        humanoid.WalkSpeed = 0
        hrp.Anchored       = true

        if toggles.camShake then
            if camShakeConn then camShakeConn:Disconnect() end
            camShakeConn = RunService.RenderStepped:Connect(function()
                if not isCharging then return end
                local t   = tick()
                local mult     = 0.8
                local shakeAmt = (chargePhase == 5 and 0.009) or (chargePhase == 4 and 0.023) or (chargePhase == 3 and 0.038) or (chargePhase == 2 and 0.055) or 0.032
                camera.CFrame = camera.CFrame * CFrame.new(
                    math.sin(t * 23 * mult) * shakeAmt,
                    math.sin(t * 29 * mult) * shakeAmt,
                    math.sin(t * 19 * mult) * shakeAmt
                )
            end)
        end

        if toggles.charShake then
            if charShakeConn then charShakeConn:Disconnect() end
            local lastPhase3Teleport = 0
            local lastPhase4Teleport = 0

            charShakeConn = RunService.Heartbeat:Connect(function()
                if not isCharging or not hrp or not chargeBaseCF then return end
                local t = tick()

                if chargePhase == 5 then
                    return
                elseif chargePhase == 4 then
                    local teleportInterval = 0.18 + math.random() * 0.22
                    if t - lastPhase4Teleport > teleportInterval then
                        lastPhase4Teleport = t
                        local tx = (math.random() - 0.5) * 3.5
                        local tz = (math.random() - 0.5) * 3.5
                        local ty = (math.random() < 0.35) and (1.2 + math.random() * 2.8) or (0.2 + (math.random() - 0.5) * 1.6)
                        hrp.CFrame = chargeBaseCF * CFrame.new(tx, ty, tz)
                    end
                elseif chargePhase == 3 then
                    if t - lastPhase3Teleport > (0.042 + math.random() * 0.055) then
                        lastPhase3Teleport = t
                        local tx = (math.random() - 0.5) * 1.55
                        local ty = 0.35 + (math.random() - 0.5) * 0.95
                        local tz = (math.random() - 0.5) * 1.55
                        hrp.CFrame = chargeBaseCF * CFrame.new(tx, ty, tz)
                    end
                else
                    local mult = (chargePhase == 2 and 2) or 1
                    local baseAmt = 0.09
                    local extraShake = (chargePhase == 2 and 0.28) or 0
                    local flyBob = (chargePhase >= 2) and math.sin(t * 1.15) * 1.35 or 0

                    hrp.CFrame = chargeBaseCF * CFrame.new(
                        math.sin(t * 21 * mult) * (baseAmt + extraShake),
                        math.sin(t * 26 * mult) * (baseAmt + extraShake) + flyBob,
                        math.sin(t * 23 * mult) * (baseAmt + extraShake)
                    )
                end
            end)
        end

        fullPower = (dashCount >= currentMaxDashes)
        if fullPower then
            enterPhase2()
        else
            nextRecharge = tick() + rechargeInterval
            phase2RandomTriggerTime = tick() + math.random(CFG.phase2RandomMin, CFG.phase2RandomMax)
        end

        updateChargeBar()
    else
        resetEnhancements()
        nextRecharge = math.huge
        chargeBaseCF = nil
        phase2RandomTriggerTime = 0

        if camShakeConn  then camShakeConn:Disconnect();  camShakeConn  = nil end
        if charShakeConn then charShakeConn:Disconnect(); charShakeConn = nil end

        humanoid.WalkSpeed = originalWalkSpeed
        hrp.Anchored       = originalAnchored

        chargeParticles.Enabled     = false
        ringParticles.Enabled       = false
        yellowRingParticles.Enabled = false
        centralGlow.Enabled         = false
        for _, b in ipairs(lightningBeams) do if b.beam then b.beam.Enabled = false end end

        chargeSoundA:Stop(); chargeSoundA.Volume = 0
        chargeSoundB:Stop(); chargeSoundB.Volume = 0

        if tracks.charge then pcall(tracks.charge.Stop, tracks.charge, 0.2) end
        if tracks.fullCharge then pcall(tracks.fullCharge.Stop, tracks.fullCharge, 0.2) end
        if tracks.ultraCharge then pcall(tracks.ultraCharge.Stop, tracks.ultraCharge, 0.2) end
        if tracks.superUltraCharge then pcall(tracks.superUltraCharge.Stop, tracks.superUltraCharge, 0.2) end

        playOnly(tracks.idle)
        playSound(CFG.chargeReturnSound, hrp, 0.8)

        if hasPhase4Unlocked then
            task.spawn(function()
                while not isCharging and dashCount < currentMaxDashes do
                    task.wait(rechargeInterval)
                    if isCharging then break end
                    dashCount = math.min(dashCount + 1, currentMaxDashes)
                    updateDashBar()
                end
            end)
        end

        task.delay(0.05, function()
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                task.wait(0.03)
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)

        updateChargeBar()
    end
end

--// NO FALL DAMAGE (unchanged)
local function enableNoFall(char)
    local humanoid = char:WaitForChild("Humanoid", 5)
    local root     = char:WaitForChild("HumanoidRootPart", 5)
    if not humanoid or not root then return end

    local noFallConn = RunService.Heartbeat:Connect(function()
        local state = humanoid:GetState()
        if state ~= Enum.HumanoidStateType.Freefall and state ~= Enum.HumanoidStateType.FallingDown then return end
        local velY = root.AssemblyLinearVelocity.Y
        if velY < -80 then
            root.AssemblyLinearVelocity = Vector3.new(
                root.AssemblyLinearVelocity.X,
                math.max(velY, -46),
                root.AssemblyLinearVelocity.Z
            )
            if velY < -120 then root:ApplyImpulse(Vector3.new(0, 800, 0)) end
        end
    end)

    local landConn = humanoid.StateChanged:Connect(function(old, new)
        if new ~= Enum.HumanoidStateType.Landed then return end
        if old ~= Enum.HumanoidStateType.Freefall and old ~= Enum.HumanoidStateType.FallingDown then return end
        if root.AssemblyLinearVelocity.Magnitude > 60 then
            task.delay(0.1, function()
                if humanoid and humanoid.Parent then
                    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                    task.wait(0.05)
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                end
            end)
        end
    end)

    char.AncestryChanged:Connect(function()
        noFallConn:Disconnect()
        landConn:Disconnect()
    end)
end

--// CHARACTER INIT (unchanged)
local function initCharacter(char)
    disconnectAll(connections)
    if camShakeConn  then camShakeConn:Disconnect();  camShakeConn  = nil end
    if charShakeConn then charShakeConn:Disconnect(); charShakeConn = nil end
    if sunConn       then sunConn:Disconnect();       sunConn       = nil end
    if phase4FlashThread then task.cancel(phase4FlashThread); phase4FlashThread = nil end
    if passiveDashConn then passiveDashConn:Disconnect(); passiveDashConn = nil end

    for _, t in pairs(tracks) do if t and t.Stop then pcall(t.Stop, t) end end
    tracks = {}

    if sunOrb then sunOrb:Destroy(); sunOrb = nil end
    if chargeAtt then chargeAtt:Destroy(); chargeAtt = nil end
    for _, b in ipairs(lightningBeams) do
        if b.beam then b.beam:Destroy() end
        if b.a0 then b.a0:Destroy() end
        if b.a1 then b.a1:Destroy() end
    end
    lightningBeams = {}

    isDashing      = false
    isCharging     = false
    fullPower      = false
    chargePhase    = 1
    fullPowerStartTime = 0
    phase3StartTime = 0
    phase4StartTime = 0
    phase2RandomTriggerTime = 0

    if not hasPhase4Unlocked then
        currentMaxDashes    = CFG.maxDashes
        currentDashRecharge = CFG.dashRecharge
        rechargeInterval    = currentDashRecharge / currentMaxDashes
    end
    dashCount      = currentMaxDashes
    dashCooldown   = false
    punchCooldown  = false
    nextRecharge   = math.huge
    chargeBaseCF   = nil
    chargeParticles, ringParticles, yellowRingParticles, centralGlow = nil, nil, nil, nil
    chargeSoundA, chargeSoundB = nil, nil

    updateDashBar()
    updateChargeBar()

    local humanoid = char:WaitForChild("Humanoid", 8)
    local hrp      = char:WaitForChild("HumanoidRootPart", 8)
    if not humanoid or not hrp then return end

    startBackgroundMusic(hrp)

    if hasPhase5Unlocked then
        nextRecharge = tick() + CFG.phase5PassiveRecharge
        startPassiveDashRecharge()
    end

    tracks.idle            = loadAnim(humanoid, ANIM.idle,            true,  Enum.AnimationPriority.Idle)
    tracks.walk            = loadAnim(humanoid, ANIM.walk,            true,  Enum.AnimationPriority.Movement)
    tracks.jump            = loadAnim(humanoid, ANIM.jump,            false, Enum.AnimationPriority.Action)
    tracks.dash            = loadAnim(humanoid, ANIM.dash,            false, Enum.AnimationPriority.Action4)
    tracks.punch           = loadAnim(humanoid, ANIM.punch,           false, Enum.AnimationPriority.Action4)
    tracks.charge          = loadAnim(humanoid, ANIM.charge,          true,  Enum.AnimationPriority.Action4)
    tracks.fullCharge      = loadAnim(humanoid, ANIM.fullCharge,      true,  Enum.AnimationPriority.Action4)
    tracks.ultraCharge     = loadAnim(humanoid, ANIM.ultraCharge,     true,  Enum.AnimationPriority.Action4)
    tracks.superUltraCharge = loadAnim(humanoid, ANIM.superUltraCharge, true, Enum.AnimationPriority.Action4)
    tracks.divineAscension  = loadAnim(humanoid, ANIM.divineAscension,  true, Enum.AnimationPriority.Action4)

    tracks.idle:Play()

    connections.run = humanoid.Running:Connect(function(speed)
        if isDashing or isCharging then return end
        if speed > 0.5 then
            playOnly(tracks.walk, 0.2, CFG.walkSpeed)
        else
            playOnly(tracks.idle, 0.2)
        end
    end)

    connections.jump = humanoid.StateChanged:Connect(function(_, new)
        if new == Enum.HumanoidStateType.Jumping and not isDashing and not isCharging then
            playOnly(tracks.jump, 0.1, 1)
        end
    end)

    connections.recharge = RunService.Heartbeat:Connect(function()
        if not isCharging or dashCount >= currentMaxDashes then return end
        if tick() >= nextRecharge then
            dashCount    = math.min(dashCount + 1, currentMaxDashes)
            nextRecharge = tick() + rechargeInterval
            updateDashBar()
        end
    end)

    connections.phaseProgression = RunService.Heartbeat:Connect(function()
        if not isCharging then return end
        local now = tick()

        if chargePhase == 1 and not fullPower and phase2RandomTriggerTime > 0 and now >= phase2RandomTriggerTime then
            enterPhase2()
        elseif chargePhase == 2 and now - fullPowerStartTime >= 10 then
            enterPhase3()
        elseif chargePhase == 3 and phase3StartTime > 0 and now - phase3StartTime >= CFG.phase3ToPhase4Time then
            enterPhase4()
        elseif chargePhase == 4 and phase4StartTime > 0 and now - phase4StartTime >= CFG.phase4ToPhase5Time then
            enterPhase5()
        end
    end)

    enableNoFall(char)
    createTitle(char)
    task.delay(0.4, function()
        if hrp and hrp.Parent then createSunOrb(hrp) end
    end)
end

