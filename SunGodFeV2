--// TOGGLE CHARGE
local camShakeConn, charShakeConn

local function toggleCharge(hrp)
    if not hrp then return end
    local char     = hrp.Parent
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return end

    -- Cancel any active emote before charging
    if isEmoting then stopEmote() end

    setupCharge(hrp)
    isCharging = not isCharging

    if isCharging then
        persistentSunColor  = CFG.sunColor
        persistentLightColor = CFG.sunColor

        updateSunOrbPhase(1)

        originalWalkSpeed    = humanoid.WalkSpeed
        originalAnchored     = hrp.Anchored
        chargeBaseCF         = hrp.CFrame

        chargePhase            = 1
        orbPhase               = 1
        fullPowerStartTime     = tick()
        phase3StartTime        = 0
        phase4StartTime        = 0
        phase2RandomTriggerTime = 0

        updateSunGodTitle(chargePhase)

        playOnly(tracks.charge)

        chargeParticles.Enabled     = true
        ringParticles.Enabled       = true
        yellowRingParticles.Enabled = true
        centralGlow.Enabled         = true
        for _, b in ipairs(lightningBeams) do if b.beam then b.beam.Enabled = true end end

        startFlicker()
        ringLoop(ringParticles, 1.8)
        ringLoop(yellowRingParticles, 1.4)
        chargeSoundLoop()

        local ti = TweenInfo.new(CFG.powerupTime, Enum.EasingStyle.Linear)
        tw(chargeSoundA, CFG.powerupTime, { Volume = 1 }, Enum.EasingStyle.Linear)
        tw(chargeSoundB, CFG.powerupTime, { Volume = 1 }, Enum.EasingStyle.Linear)
        TweenService:Create(chargeParticles, ti, { Rate = 1300 }):Play()
        TweenService:Create(centralGlow,     ti, { Rate = 12  }):Play()

        humanoid.WalkSpeed = 0
        hrp.Anchored       = true

        if toggles.camShake then
            if camShakeConn then camShakeConn:Disconnect() end
            camShakeConn = RunService.RenderStepped:Connect(function()
                if not isCharging then return end
                local t       = tick()
                local mult    = 0.8
                local shakeAmt = (chargePhase == 5 and 0.009) or (chargePhase == 4 and 0.023) or (chargePhase == 3 and 0.038) or (chargePhase == 2 and 0.055) or 0.032
                camera.CFrame = camera.CFrame * CFrame.new(
                    math.sin(t * 23 * mult) * shakeAmt,
                    math.sin(t * 29 * mult) * shakeAmt,
                    math.sin(t * 19 * mult) * shakeAmt
                )
            end)
        end

        if toggles.charShake then
            if charShakeConn then charShakeConn:Disconnect() end

            local bp = Instance.new("BodyPosition")
            bp.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bp.P        = 8000
            bp.D        = 600
            bp.Position = hrp.Position
            bp.Parent   = hrp

            local bg = Instance.new("BodyGyro")
            bg.MaxTorque = Vector3.new(0, 1e5, 0)  -- only yaw, don't fight tilt
            bg.P         = 6000
            bg.D         = 500
            bg.CFrame    = hrp.CFrame
            bg.Parent    = hrp

            -- Per-phase drift config: { radius, bobHeight, speed, changeInterval }
            -- All smooth lerp-based, no snapping
            local DRIFT_CFG = {
                [1] = { radius = 0.18, bob = 0.10, speed = 2.5, interval = 2.8 },
                [2] = { radius = 0.45, bob = 0.28, speed = 3.5, interval = 2.2 },
                [3] = { radius = 0.90, bob = 0.55, speed = 5.0, interval = 1.6 },
                [4] = { radius = 1.60, bob = 0.90, speed = 7.0, interval = 1.1 },
                [5] = { radius = 0.30, bob = 0.50, speed = 2.0, interval = 3.5 },  -- divine: calm, floaty
            }

            local currentOffset  = Vector3.new(0, 0, 0)
            local targetOffset   = Vector3.new(0, 0, 0)
            local lastChangeTime = tick()

            local function pickNewTarget(p)
                local cfg = DRIFT_CFG[p] or DRIFT_CFG[1]
                local angle = math.random() * math.pi * 2
                local dist  = cfg.radius * (0.5 + math.random() * 0.5)
                return Vector3.new(
                    math.cos(angle) * dist,
                    cfg.bob * (math.random() - 0.5) * 2,
                    math.sin(angle) * dist
                )
            end

            charShakeConn = RunService.Heartbeat:Connect(function(dt)
                if not isCharging or not hrp or not hrp.Parent then
                    if bp and bp.Parent then bp:Destroy() end
                    if bg and bg.Parent then bg:Destroy() end
                    return
                end

                local t   = tick()
                local p   = math.clamp(chargePhase, 1, 5)
                local cfg = DRIFT_CFG[p]

                -- Pick a new drift target every `interval` seconds
                if t - lastChangeTime >= cfg.interval then
                    lastChangeTime = t
                    targetOffset   = pickNewTarget(p)
                end

                -- Smoothly lerp currentOffset toward target each frame
                local lerpSpeed = cfg.speed * dt
                currentOffset = currentOffset:Lerp(targetOffset, math.min(lerpSpeed, 1))

                -- Apply on top of wherever the player actually is right now
                bp.Position = hrp.Position + currentOffset
                bg.CFrame   = CFrame.new(hrp.Position) * (hrp.CFrame - hrp.CFrame.Position)
            end)

            local oldConn = charShakeConn
            task.spawn(function()
                while charShakeConn == oldConn and isCharging do task.wait(0.1) end
                if bp and bp.Parent then bp:Destroy() end
                if bg and bg.Parent then bg:Destroy() end
            end)
        end

        fullPower = (dashCount >= currentMaxDashes)
        if fullPower then
            enterPhase2()
        else
            nextRecharge = tick() + rechargeInterval
            phase2RandomTriggerTime = tick() + math.random(CFG.phase2RandomMin, CFG.phase2RandomMax)
        end

        updateChargeBar()
    else
        resetEnhancements()
        nextRecharge           = math.huge
        chargeBaseCF           = nil
        phase2RandomTriggerTime = 0

        if camShakeConn  then camShakeConn:Disconnect();  camShakeConn  = nil end
        if charShakeConn then charShakeConn:Disconnect(); charShakeConn = nil end

        -- Clean up any BodyPosition/BodyGyro left on the HRP from charShake
        if hrp and hrp.Parent then
            local bp = hrp:FindFirstChildWhichIsA("BodyPosition")
            local bg = hrp:FindFirstChildWhichIsA("BodyGyro")
            if bp then bp:Destroy() end
            if bg then bg:Destroy() end
        end

        humanoid.WalkSpeed = originalWalkSpeed
        hrp.Anchored       = originalAnchored

        chargeParticles.Enabled     = false
        ringParticles.Enabled       = false
        yellowRingParticles.Enabled = false
        centralGlow.Enabled         = false
        for _, b in ipairs(lightningBeams) do if b.beam then b.beam.Enabled = false end end

        chargeSoundA:Stop(); chargeSoundA.Volume = 0
        chargeSoundB:Stop(); chargeSoundB.Volume = 0

        if tracks.charge          then pcall(tracks.charge.Stop,          tracks.charge,          0.2) end
        if tracks.fullCharge      then pcall(tracks.fullCharge.Stop,      tracks.fullCharge,      0.2) end
        if tracks.ultraCharge     then pcall(tracks.ultraCharge.Stop,     tracks.ultraCharge,     0.2) end
        if tracks.superUltraCharge then pcall(tracks.superUltraCharge.Stop, tracks.superUltraCharge, 0.2) end

        playOnly(tracks.idle)
        playSound(CFG.chargeReturnSound, hrp, 0.8)

        if hasPhase4Unlocked then
            task.spawn(function()
                while not isCharging and dashCount < currentMaxDashes do
                    task.wait(rechargeInterval)
                    if isCharging then break end
                    dashCount = math.min(dashCount + 1, currentMaxDashes)
                    updateDashBar()
                end
            end)
        end

        task.delay(0.05, function()
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                task.wait(0.03)
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)

        updateChargeBar()
    end
end

--// NO FALL DAMAGE
local function enableNoFall(char)
    local humanoid = char:WaitForChild("Humanoid", 5)
    local root     = char:WaitForChild("HumanoidRootPart", 5)
    if not humanoid or not root then return end

    local noFallConn = RunService.Heartbeat:Connect(function()
        local state = humanoid:GetState()
        if state ~= Enum.HumanoidStateType.Freefall and state ~= Enum.HumanoidStateType.FallingDown then return end
        local velY = root.AssemblyLinearVelocity.Y
        if velY < -80 then
            root.AssemblyLinearVelocity = Vector3.new(
                root.AssemblyLinearVelocity.X,
                math.max(velY, -46),
                root.AssemblyLinearVelocity.Z
            )
            if velY < -120 then root:ApplyImpulse(Vector3.new(0, 800, 0)) end
        end
    end)

    local landConn = humanoid.StateChanged:Connect(function(old, new)
        if new ~= Enum.HumanoidStateType.Landed then return end
        if old ~= Enum.HumanoidStateType.Freefall and old ~= Enum.HumanoidStateType.FallingDown then return end
        if root.AssemblyLinearVelocity.Magnitude > 60 then
            task.delay(0.1, function()
                if humanoid and humanoid.Parent then
                    humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                    task.wait(0.05)
                    humanoid:ChangeState(Enum.HumanoidStateType.Running)
                end
            end)
        end
    end)

    char.AncestryChanged:Connect(function()
        noFallConn:Disconnect()
        landConn:Disconnect()
    end)
end

--// CHARACTER INIT
local ambientConn
local function initCharacter(char)
    disconnectAll(connections)
    if camShakeConn      then camShakeConn:Disconnect();      camShakeConn      = nil end
    if charShakeConn     then charShakeConn:Disconnect();     charShakeConn     = nil end
    if sunConn           then sunConn:Disconnect();           sunConn           = nil end
    if phase4FlashThread then task.cancel(phase4FlashThread); phase4FlashThread = nil end
    if phase5FlashThread then task.cancel(phase5FlashThread); phase5FlashThread = nil end
    if phase5FloatConn   then phase5FloatConn:Disconnect();   phase5FloatConn   = nil end
    if passiveDashConn   then passiveDashConn:Disconnect();   passiveDashConn   = nil end
    if ambientConn       then ambientConn:Disconnect();       ambientConn       = nil end

    for _, t in pairs(tracks) do if t and t.Stop then pcall(t.Stop, t) end end
    tracks = {}

    if sunOrb    then sunOrb:Destroy();    sunOrb    = nil end
    sunFire   = nil
    sunCorona = nil
    if chargeAtt then chargeAtt:Destroy(); chargeAtt = nil end

    -- Clean up any active emote on respawn
    if emoteTrack then pcall(emoteTrack.Stop, emoteTrack, 0) end
    emoteTrack   = nil
    isEmoting    = false
    for _, b in ipairs(lightningBeams) do
        if b.beam then b.beam:Destroy() end
        if b.a0   then b.a0:Destroy()  end
        if b.a1   then b.a1:Destroy()  end
    end
    lightningBeams = {}

    isDashing              = false
    isCharging             = false
    fullPower              = false
    chargePhase            = 1
    fullPowerStartTime     = 0
    phase3StartTime        = 0
    phase4StartTime        = 0
    phase2RandomTriggerTime = 0

    if not hasPhase4Unlocked then
        currentMaxDashes    = CFG.maxDashes
        currentDashRecharge = CFG.dashRecharge
        rechargeInterval    = currentDashRecharge / currentMaxDashes
    end
    dashCount     = currentMaxDashes
    dashCooldown  = false
    punchCooldown = false
    nextRecharge  = math.huge
    chargeBaseCF  = nil
    chargeParticles, ringParticles, yellowRingParticles, centralGlow = nil, nil, nil, nil
    chargeSoundA, chargeSoundB = nil, nil

    updateDashBar()
    updateChargeBar()

    local humanoid = char:WaitForChild("Humanoid", 8)
    local hrp      = char:WaitForChild("HumanoidRootPart", 8)
    if not humanoid or not hrp then return end

    startBackgroundMusic(hrp)

    if hasPhase5Unlocked then
        nextRecharge = tick() + CFG.phase5PassiveRecharge
        startPassiveDashRecharge()
    end

    tracks.idle             = loadAnim(humanoid, ANIM.idle,             true,  Enum.AnimationPriority.Idle)
    tracks.walk             = loadAnim(humanoid, ANIM.walk,             true,  Enum.AnimationPriority.Movement)
    tracks.jump             = loadAnim(humanoid, ANIM.jump,             false, Enum.AnimationPriority.Action)
    tracks.dash             = loadAnim(humanoid, ANIM.dash,             false, Enum.AnimationPriority.Action4)
    tracks.punch            = loadAnim(humanoid, ANIM.punch,            false, Enum.AnimationPriority.Action4)
    tracks.charge           = loadAnim(humanoid, ANIM.charge,           true,  Enum.AnimationPriority.Action4)
    tracks.fullCharge       = loadAnim(humanoid, ANIM.fullCharge,       true,  Enum.AnimationPriority.Action4)
    tracks.ultraCharge      = loadAnim(humanoid, ANIM.ultraCharge,      true,  Enum.AnimationPriority.Action4)
    tracks.superUltraCharge = loadAnim(humanoid, ANIM.superUltraCharge, true,  Enum.AnimationPriority.Action4)
    tracks.divineAscension  = loadAnim(humanoid, ANIM.divineAscension,  true,  Enum.AnimationPriority.Action4)

    tracks.idle:Play()

    --// AMBIENT EFFECTS
    local lastAmbientTime  = 0
    local nextAmbientDelay = 3 + math.random() * 4

    local function getAmbientPhaseColor()
        return DASH_BALL_COLORS[orbPhase] or DASH_BALL_COLORS[1]
    end

    -- Returns how long to wait before the next ambient trigger, scaling down with orbPhase
    -- Tuned down: phase1: 5–10s  phase2: 4–8s  phase3: 3–6s  phase4: 2–4.5s  phase5: 2.5–5s (divine is calmer)
    local AMBIENT_DELAY_MIN = { 5.0, 4.0, 3.0, 2.0, 2.5 }
    local AMBIENT_DELAY_MAX = { 10.0, 8.0, 6.0, 4.5, 5.0 }

    local function nextDelay()
        local p   = math.clamp(orbPhase, 1, 5)
        local mn  = AMBIENT_DELAY_MIN[p]
        local mx  = AMBIENT_DELAY_MAX[p]
        return mn + math.random() * (mx - mn)
    end

    local function doAmbientHandFire(character)
        local hands = {}
        local rh = character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm")
        local lh = character:FindFirstChild("LeftHand")  or character:FindFirstChild("Left Arm")
        if rh then table.insert(hands, rh) end
        if lh then table.insert(hands, lh) end
        if #hands == 0 then return end

        local p    = math.clamp(orbPhase, 1, 5)
        -- At higher phases always fire both hands; at phase 1 only sometimes
        local bothChance = 0.15 + p * 0.17   -- p1=0.32  p5=1.0
        local targets = (math.random() < bothChance) and hands or { hands[math.random(1, #hands)] }
        local cols    = getAmbientPhaseColor()

        -- Phase 5 (Divine) is intentionally subtle — toned down size and duration
        -- Size and duration grow with phase, but capped lower than before
        local sizeBase = 0.2 + p * 0.10    -- p1=0.30  p5=0.70  (was 0.48–1.2)
        local sizePeak = 0.9 + p * 0.22    -- p1=1.12  p5=2.00  (was 1.85–3.65)
        local duration = (0.3 + math.random() * 0.3) + p * 0.10

        for _, hand in ipairs(targets) do
            local ghost = Instance.new("Part")
            ghost.Anchored    = true
            ghost.CanCollide  = false
            ghost.Transparency = 1
            ghost.Size        = Vector3.new(0.1, 0.1, 0.1)
            ghost.CFrame      = hand.CFrame
            ghost.Parent      = workspace
            Debris:AddItem(ghost, duration + 1.0)

            local pe = Instance.new("ParticleEmitter", ghost)
            pe.Texture       = "rbxasset://textures/particles/fire_main.dds"
            pe.Size          = NumberSequence.new{
                NumberSequenceKeypoint.new(0,   sizeBase),
                NumberSequenceKeypoint.new(0.3, sizePeak),
                NumberSequenceKeypoint.new(0.7, sizeBase * 1.2),
                NumberSequenceKeypoint.new(1,   0),
            }
            pe.Lifetime      = NumberRange.new(0.28 + p * 0.07, 0.6 + p * 0.12)
            pe.Rate          = 30 + p * 14    -- was 60 + p * 30
            pe.Speed         = NumberRange.new(1.5 + p * 0.5, 5 + p * 1.2)
            pe.SpreadAngle   = Vector2.new(70, 70)
            pe.RotSpeed      = NumberRange.new(-140, 140)
            pe.LightEmission = 1
            pe.Transparency  = NumberSequence.new{
                NumberSequenceKeypoint.new(0,   0.05),
                NumberSequenceKeypoint.new(0.5, 0.25),
                NumberSequenceKeypoint.new(1,   1.0),
            }
            pe.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0,   cols[1]),
                ColorSequenceKeypoint.new(0.5, cols[2]),
                ColorSequenceKeypoint.new(1,   cols[3]),
            }
            task.delay(duration, function()
                if pe and pe.Parent then pe.Enabled = false end
            end)
        end
    end

    local function doAmbientLightning(hrp2)
        local p     = math.clamp(orbPhase, 1, 5)
        -- Reduced bolt count — divine phase especially toned down
        local maxExtra = (p == 5) and 1 or math.floor(p * 0.5)
        local count = 1 + math.random(0, maxExtra)
        local cols  = BOLT_COLORS[orbPhase] or BOLT_COLORS[1]
        for i = 1, count do
            task.delay(i * 0.07, function()
                if not hrp2 or not hrp2.Parent then return end
                local b = makeBolt(hrp2)
                if b.beam then
                    b.beam.Color  = ColorSequence.new{
                        ColorSequenceKeypoint.new(0, cols[1]),
                        ColorSequenceKeypoint.new(1, cols[2]),
                    }
                    -- Thinner beams than before, divine capped lower
                    local widthMult = (p == 5) and 0.5 or 1.0
                    b.beam.Width0        = (0.18 + p * 0.09) * widthMult
                    b.beam.Width1        = (0.04 + p * 0.03) * widthMult
                    b.beam.LightEmission = 0.6 + p * 0.18
                    task.spawn(function()
                        for _ = 1, 4 do
                            task.wait(0.055)
                            if b.beam and b.beam.Parent then
                                b.beam.Transparency = NumberSequence.new(math.random(0, 60) / 100)
                                if b.a1 and b.a1.Parent then
                                    b.a1.Position = Vector3.new(
                                        math.random(-7, 7),
                                        math.random(-4, 10),
                                        math.random(-7, 7)
                                    )
                                end
                            end
                        end
                        if b.beam then b.beam:Destroy() end
                        if b.a0   then b.a0:Destroy()  end
                        if b.a1   then b.a1:Destroy()  end
                    end)
                end
            end)
        end
    end

    ambientConn = RunService.Heartbeat:Connect(function()
        if isCharging then return end
        if gState.active then return end   -- griefer mode handles its own idle fx
        local now = tick()
        if now - lastAmbientTime < nextAmbientDelay then return end
        lastAmbientTime  = now
        nextAmbientDelay = nextDelay()

        local char2 = lp.Character
        if not char2 then return end
        local hrp2 = char2:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end

        -- At higher phases, fire tends to both hands + lightning together
        -- Divine (p5) is intentionally kept subtle — lower combo chance
        local p    = math.clamp(orbPhase, 1, 5)
        local roll = math.random()
        local bothThreshold  = (p == 5) and 0.20 or (0.10 + p * 0.10)   -- p1≈0.20  p4≈0.50  p5=0.20 (divine stays calm)
        local lightningOnly  = bothThreshold + 0.20
        if roll < bothThreshold then
            doAmbientHandFire(char2)
            doAmbientLightning(hrp2)
        elseif roll < lightningOnly then
            doAmbientLightning(hrp2)
        else
            doAmbientHandFire(char2)
        end
    end)

    connections.run = humanoid.Running:Connect(function(speed)
        if gState.active then return end   -- griefer mode owns animations
        if isDashing or isCharging then return end
        if speed > 0.5 then
            playOnly(tracks.walk, 0.2, CFG.walkSpeed)
        else
            playOnly(tracks.idle, 0.2)
        end
    end)

    connections.jump = humanoid.StateChanged:Connect(function(_, new)
        if gState.active then return end   -- griefer mode owns animations
        if new == Enum.HumanoidStateType.Jumping and not isDashing and not isCharging then
            playOnly(tracks.jump, 0.1, 1)
        end
    end)

    connections.recharge = RunService.Heartbeat:Connect(function()
        if not isCharging or dashCount >= currentMaxDashes then return end
        if tick() >= nextRecharge then
            dashCount    = math.min(dashCount + 1, currentMaxDashes)
            nextRecharge = tick() + rechargeInterval
            updateDashBar()
        end
    end)

    connections.phaseProgression = RunService.Heartbeat:Connect(function()
        if not isCharging then return end
        local now = tick()
        if chargePhase == 1 and not fullPower and phase2RandomTriggerTime > 0 and now >= phase2RandomTriggerTime then
            enterPhase2()
        elseif chargePhase == 2 and now - fullPowerStartTime >= 10 then
            enterPhase3()
        elseif chargePhase == 3 and phase3StartTime > 0 and now - phase3StartTime >= CFG.phase3ToPhase4Time then
            enterPhase4()
        elseif chargePhase == 4 and phase4StartTime > 0 and now - phase4StartTime >= CFG.phase4ToPhase5Time then
            enterPhase5()
        end
    end)

    enableNoFall(char)
    createTitle(char)
    task.delay(0.4, function()
        if hrp and hrp.Parent then createSunOrb(hrp) end
    end)
end

--// EMOTE SYSTEM
local isEmoting         = false
local emoteTrack        = nil
local emoteSavedSpeed   = 16
local emoteSavedAnchored = false

local function startEmote()
    local char = lp.Character
    if not char then return end
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    local hrp      = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then return end

    -- Can't emote while charging
    if isCharging then return end

    -- Stop any playing tracks
    for _, t in pairs(tracks) do
        if t and t.IsPlaying then pcall(t.Stop, t, 0.15) end
    end
    if emoteTrack then pcall(emoteTrack.Stop, emoteTrack, 0.1) end

    -- Pick a random emote
    local chosenId = EMOTE_IDS[math.random(1, #EMOTE_IDS)]
    local anim = Instance.new("Animation")
    anim.AnimationId = chosenId
    emoteTrack = humanoid:LoadAnimation(anim)
    emoteTrack.Priority = Enum.AnimationPriority.Action4
    emoteTrack.Looped   = true

    -- Freeze the character
    emoteSavedSpeed    = humanoid.WalkSpeed
    emoteSavedAnchored = hrp.Anchored
    humanoid.WalkSpeed = 0
    hrp.Anchored       = true

    emoteTrack:Play(0.2)
    isEmoting = true
end

local function stopEmote()
    local char = lp.Character
    if not char then return end
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    local hrp      = char:FindFirstChild("HumanoidRootPart")

    if emoteTrack then
        pcall(emoteTrack.Stop, emoteTrack, 0.25)
        emoteTrack = nil
    end

    if humanoid then humanoid.WalkSpeed = emoteSavedSpeed end
    if hrp      then hrp.Anchored       = emoteSavedAnchored end

    isEmoting = false

    -- Resume idle so the character doesn't T-pose
    if tracks.idle then tracks.idle:Play(0.2) end

    -- Let the humanoid walk again
    if humanoid then
        task.delay(0.05, function()
            if humanoid and humanoid.Parent then
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
                task.wait(0.03)
                humanoid:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)
    end
end

--// INPUT
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if gState.active then return end   -- griefer mode owns input
    local char = lp.Character
    if not char then return end
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    local hrp      = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then return end

    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if isEmoting then return end  -- block dash/punch while emoting
        if isCharging and chargePhase < 3 then return end
        if doDash(hrp, humanoid) then
            doPunch(char)
        end
    end

    if input.KeyCode == Enum.KeyCode.Z then
        if isEmoting then return end  -- block charge while emoting
        toggleCharge(hrp)
    end

    if input.KeyCode == Enum.KeyCode.V then
        if isCharging then return end  -- can't emote while charging
        if isEmoting then
            stopEmote()
        else
            startEmote()
        end
    end
end)

