-- Griefer main heartbeat connection
local grieferHeartbeat = nil

local function startGrieferMode(char)
    if not char then return end
    grieferLoadAnims(char)
    gState.stamina   = GRIEFER_CFG.SPRINT_MAX
    gState.sprintCD  = false
    gState.attacking = false
    gState.blocking  = false
    gState.sprinting = false
    gState.dashCD    = false
    gCurrentGroup    = ""

    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    local hrpG     = char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrpG then return end

    humanoid.WalkSpeed = GRIEFER_CFG.NORMAL_SPEED
    gPlayGroup("idle", true)

    -- Movement and animation are handled entirely in grieferHeartbeat.
    -- No separate Running/StateChanged connections — they would fight the Heartbeat and cause stutter.

    grieferHeartbeat = RunService.Heartbeat:Connect(function(dt)
        if not gState.active then return end
        local char2 = lp.Character
        if not char2 then return end
        local hrp2 = char2:FindFirstChild("HumanoidRootPart")
        if not hrp2 then return end
        local hum2 = char2:FindFirstChildWhichIsA("Humanoid")

        local vel    = hrp2.AssemblyLinearVelocity
        local moving = Vector2.new(vel.X, vel.Z).Magnitude > 1.0

        -- Stamina
        if gState.sprinting and moving then
            gState.stamina = math.max(0, gState.stamina - GRIEFER_CFG.SPRINT_DRAIN * dt)
            if gState.stamina <= 0 then
                gState.sprintCD  = true
                gState.sprinting = false
            end
        else
            local rr = moving and GRIEFER_CFG.SPRINT_REGEN_MOVE or GRIEFER_CFG.SPRINT_REGEN_IDLE
            gState.stamina = math.min(GRIEFER_CFG.SPRINT_MAX, gState.stamina + rr * dt)
            if gState.sprintCD and gState.stamina >= GRIEFER_CFG.SPRINT_MAX * GRIEFER_CFG.SPRINT_RESUME_PCT then
                gState.sprintCD = false
            end
        end

        -- Sprint flag
        gState.sprinting = gState.shiftHeld and moving
            and not gState.attacking and not gState.blocking
            and not gState.sprintCD and gState.stamina > 0

        gSyncSpeed(char2)
        updateGrieferStaminaBar(gState.stamina / GRIEFER_CFG.SPRINT_MAX)

        if not gState.attacking and not gState.blocking and not gIsEmoting then
            gRefreshMovement(char2)
        end
    end)
end

local function stopGrieferMode(char)
    if grieferHeartbeat then grieferHeartbeat:Disconnect(); grieferHeartbeat = nil end
    for k, c in pairs(gConnections) do
        if c and c.Disconnect then c:Disconnect() end
        gConnections[k] = nil
    end
    -- Stop emote if active
    if gIsEmoting then
        if gEmoteTrack and gEmoteTrack.IsPlaying then gEmoteTrack:Stop(0) end
        gEmoteTrack  = nil
        gIsEmoting   = false
        local hrpG = char and char:FindFirstChild("HumanoidRootPart")
        if hrpG then hrpG.Anchored = false end
    end
    gStopAll(0.2)
    gActiveTrack  = nil
    gCurrentGroup = ""
    -- Restore walkspeed to sun god default
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if humanoid then humanoid.WalkSpeed = 16 end
end

-- Griefer attack
local function gDoAttack(char)
    if not gState.active then return end
    if gState.attacking or gState.blocking then return end
    local now = tick()
    if (now - gLastAttack) < GRIEFER_CFG.ATTACK_COOLDOWN then return end

    gLastAttack      = now
    gState.attacking = true

    local hrpG     = char and char:FindFirstChild("HumanoidRootPart")
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if not hrpG or not humanoid then gState.attacking = false; return end

    -- Lock movement completely during attack
    humanoid.WalkSpeed  = 0
    humanoid.AutoRotate = false

    local atkTrack = gTracks.attack and gTracks.attack[1]
    if not atkTrack then
        humanoid.WalkSpeed  = GRIEFER_CFG.NORMAL_SPEED
        humanoid.AutoRotate = true
        gState.attacking    = false
        return
    end

    gStopAll(0)
    atkTrack.Looped = false
    atkTrack:Play(0.08)
    atkTrack:AdjustSpeed(GRIEFER_CFG.ATTACK_SPEED_MOD)
    gActiveTrack  = atkTrack
    gCurrentGroup = "attack"
    local snd = Instance.new("Sound")
    snd.SoundId = GRIEFER_CFG.ATTACK_SOUND_ID
    snd.Volume  = 0.9
    snd.RollOffMaxDistance = 40
    snd.Parent  = hrpG
    snd:Play()
    Debris:AddItem(snd, 3)

    local done = false
    local t0   = tick()
    local conn
    conn = atkTrack.Stopped:Connect(function() done = true; conn:Disconnect() end)
    while not done and (tick() - t0) < GRIEFER_CFG.ATTACK_TIMEOUT do task.wait() end
    if not done then conn:Disconnect(); atkTrack:Stop(0) end

    humanoid.AutoRotate = true
    humanoid.WalkSpeed  = GRIEFER_CFG.NORMAL_SPEED
    gState.attacking    = false
    gCurrentGroup       = ""
    gSyncSpeed(char)
    gRefreshMovement(char)
end

-- Griefer dash
local function gDoDash(char)
    if not gState.active then return end
    if gState.dashCD then return end
    local hrpG = char and char:FindFirstChild("HumanoidRootPart")
    if not hrpG then return end

    gState.dashCD = true

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = hrpG.CFrame.LookVector * GRIEFER_CFG.DASH_FORCE
        + Vector3.new(0, hrpG.AssemblyLinearVelocity.Y, 0)
    bv.Parent   = hrpG
    Debris:AddItem(bv, GRIEFER_CFG.DASH_TIME)

    -- Trail
    local ta = Instance.new("Attachment", hrpG); ta.Position = Vector3.new(0, 5, 0)
    local tb = Instance.new("Attachment", hrpG); tb.Position = Vector3.new(0,-5, 0)
    local trail = Instance.new("Trail")
    trail.Attachment0 = ta; trail.Attachment1 = tb
    trail.Lifetime    = 0.18
    trail.Color       = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   Color3.fromRGB(200,  80, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,  30,  80)),
        ColorSequenceKeypoint.new(1,   Color3.fromRGB( 80,   0, 180)),
    }
    trail.LightEmission = 1
    trail.WidthScale  = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 9), NumberSequenceKeypoint.new(0.5, 5), NumberSequenceKeypoint.new(1, 0)
    }
    trail.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(0.4, 0.2), NumberSequenceKeypoint.new(1, 1)
    }
    trail.Parent = hrpG
    Debris:AddItem(trail, 0.5); Debris:AddItem(ta, 0.5); Debris:AddItem(tb, 0.5)

    -- Flame burst on hands
    grieferDashFlames(char)

    task.delay(GRIEFER_CFG.DASH_COOLDOWN, function() gState.dashCD = false end)
end

-- Griefer block
local function gStartBlock(char)
    if not gState.active then return end
    if gState.attacking or gState.blocking then return end
    gState.blocking = true
    gCurrentGroup   = "block"

    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if humanoid then humanoid.WalkSpeed = 0 end

    -- Stop only movement-layer tracks, not the block track itself
    for group, pool in pairs(gTracks) do
        if group ~= "block" then
            for _, t in ipairs(pool) do
                if t.IsPlaying then t:Stop(0.15) end
            end
        end
    end

    local bt = gTracks.block and gTracks.block[1]
    if bt then
        bt.Looped = true
        if not bt.IsPlaying then bt:Play(0.1) end
        gActiveTrack = bt
    end
end

local function gStopBlock(char)
    if not gState.active then return end
    if not gState.blocking then return end
    gState.blocking = false
    local bt = gTracks.block and gTracks.block[1]
    if bt and bt.IsPlaying then bt:Stop(0.2) end
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if humanoid then humanoid.WalkSpeed = GRIEFER_CFG.NORMAL_SPEED end
    gCurrentGroup = ""
    gSyncSpeed(char)
    gRefreshMovement(char)
end

-- Griefer emote (V key toggles, loops until V pressed again)
local function gStartEmote(char)
    if not gState.active then return end
    if gState.attacking or gState.blocking then return end
    if gIsEmoting then return end
    if #gEmoteTracks == 0 then return end

    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    local hrp      = char and char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not hrp then return end

    gStopAll(0.15)

    local track = gEmoteTracks[math.random(1, #gEmoteTracks)]
    track.Looped = true
    track:Play(0.2)
    gEmoteTrack  = track
    gIsEmoting   = true
    gCurrentGroup = "emote"

    humanoid.WalkSpeed = 0
    hrp.Anchored       = true
end

local function gStopEmote(char)
    if not gState.active then return end
    if not gIsEmoting then return end

    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    local hrp      = char and char:FindFirstChild("HumanoidRootPart")

    if gEmoteTrack and gEmoteTrack.IsPlaying then
        gEmoteTrack:Stop(0.2)
    end
    gEmoteTrack  = nil
    gIsEmoting   = false
    gCurrentGroup = ""

    if humanoid then humanoid.WalkSpeed = GRIEFER_CFG.NORMAL_SPEED end
    if hrp      then hrp.Anchored = false end

    -- Snap back to idle so there's no T-pose gap
    task.delay(0.05, function()
        if humanoid and humanoid.Parent then
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            task.wait(0.03)
            humanoid:ChangeState(Enum.HumanoidStateType.Running)
        end
    end)
    gRefreshMovement(char)
end

