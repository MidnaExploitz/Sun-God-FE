local function grieferLoadAnims(char)
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return end
    local animator = humanoid:FindFirstChildWhichIsA("Animator")
    if not animator then return end
    gTracks = {}
    for group, ids in pairs(GRIEFER_ANIM_IDS) do
        gTracks[group] = {}
        for _, id in ipairs(ids) do
            local anim = Instance.new("Animation")
            anim.AnimationId = "rbxassetid://" .. id
            local pri
            if group == "idle" then
                pri = Enum.AnimationPriority.Idle
            elseif group == "walk" or group == "jump" or group == "sprint" then
                pri = Enum.AnimationPriority.Movement
            elseif group == "block" then
                pri = Enum.AnimationPriority.Action
            else
                pri = Enum.AnimationPriority.Action4
            end
            local t = animator:LoadAnimation(anim)
            t.Priority = pri
            table.insert(gTracks[group], t)
        end
    end
    -- Load emote tracks (same pool as sun god, shared IDs)
    gEmoteTracks = {}
    for _, id in ipairs(EMOTE_IDS) do
        local anim = Instance.new("Animation")
        anim.AnimationId = id
        local t = animator:LoadAnimation(anim)
        t.Priority = Enum.AnimationPriority.Action4
        t.Looped   = true
        table.insert(gEmoteTracks, t)
    end
end

local function gStopAll(fade)
    fade = fade or 0
    for _, pool in pairs(gTracks) do
        for _, t in ipairs(pool) do
            if t.IsPlaying then t:Stop(fade) end
        end
    end
end

local function gPlayGroup(group, looped, fade)
    local pool = gTracks[group]
    if not pool or #pool == 0 then return end
    -- Only switch if we're not already playing this group
    if gCurrentGroup == group and gActiveTrack and gActiveTrack.IsPlaying then return end
    local idx   = gState.variantIdx[group]
    local track = pool[idx]
    -- Only advance variant index now that we're actually going to play it
    gState.variantIdx[group] = (idx % #pool) + 1
    -- Stop any other track that isn't this one
    for _, pool2 in pairs(gTracks) do
        for _, t in ipairs(pool2) do
            if t ~= track and t.IsPlaying then t:Stop(fade or 0.2) end
        end
    end
    track.Looped = looped
    if not track.IsPlaying then track:Play(fade or 0.15) end
    gActiveTrack  = track
    gCurrentGroup = group
end

local function gSyncSpeed(char)
    local humanoid = char and char:FindFirstChildWhichIsA("Humanoid")
    if not humanoid then return end
    if gState.attacking or gState.blocking then
        humanoid.WalkSpeed = 0
    elseif gState.sprinting then
        humanoid.WalkSpeed = GRIEFER_CFG.SPRINT_SPEED
    else
        humanoid.WalkSpeed = GRIEFER_CFG.NORMAL_SPEED
    end
end

local function gRefreshMovement(char)
    if gState.attacking or gState.blocking then return end    local hrpG = char and char:FindFirstChild("HumanoidRootPart")
    if not hrpG then return end
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    local vel    = hrpG.AssemblyLinearVelocity
    local flat   = Vector2.new(vel.X, vel.Z).Magnitude
    local moving = flat > 1.0
    local falling = humanoid and humanoid:GetState() == Enum.HumanoidStateType.Freefall

    local desired
    if falling then
        desired = "jump"
    elseif gState.sprinting and moving then
        desired = "sprint"
    elseif moving then
        desired = "walk"
    else
        desired = "idle"
    end

    -- Only switch if the desired group actually changed
    if desired == gCurrentGroup and gActiveTrack and gActiveTrack.IsPlaying then return end

    if desired == "sprint" then
        gCurrentGroup = ""   -- clear so gPlayGroup doesn't early-return
        gPlayGroup("sprint", true)
        if gTracks.sprint and gTracks.sprint[1] then
            gTracks.sprint[1]:AdjustSpeed(GRIEFER_CFG.SPRINT_ANIM_SPD)
        end
    elseif desired == "jump" then
        gCurrentGroup = ""
        gPlayGroup("jump", false)
    elseif desired == "walk" then
        gCurrentGroup = ""
        gPlayGroup("walk", true)
    else
        gCurrentGroup = ""
        gPlayGroup("idle", true)
    end
end

