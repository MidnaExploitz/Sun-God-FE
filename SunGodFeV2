local function createSunOrb(hrp)
    if not toggles.sunOrb then return end
    if gState.active then return end   -- griefer mode: no sun orb
    if sunOrb then sunOrb:Destroy() end
    if not hrp or not hrp.Parent then return end

    sunOrb              = Instance.new("Part")
    sunOrb.Name         = "SunOrb"
    sunOrb.Shape        = Enum.PartType.Ball
    sunOrb.Size         = Vector3.new(1, 1, 1)
    sunOrb.Color        = persistentSunColor
    sunOrb.Material     = CFG.sunMaterial
    sunOrb.Anchored     = true
    sunOrb.CanCollide   = false
    sunOrb.Transparency = 0.2
    sunOrb.CastShadow   = false
    sunOrb.Position     = hrp.Position + Vector3.new(0, -12, 0)
    sunOrb.Parent       = workspace

    local light = Instance.new("PointLight", sunOrb)
    light.Brightness = 4.5
    light.Range      = 30
    light.Color      = persistentLightColor

    -- Main fire emitter: bigger particles, phase-colored from the start
    sunFire = Instance.new("ParticleEmitter", sunOrb)
    sunFire.Texture      = "rbxasset://textures/particles/fire_main.dds"
    sunFire.Color        = SUN_ORB_FIRE_COLORS[chargePhase] or SUN_ORB_FIRE_COLORS[1]
    sunFire.Size         = NumberSequence.new{
        NumberSequenceKeypoint.new(0,   3.5),
        NumberSequenceKeypoint.new(0.3, 5.5),
        NumberSequenceKeypoint.new(0.7, 3.8),
        NumberSequenceKeypoint.new(1,   0.4),
    }
    sunFire.Lifetime     = NumberRange.new(2.0, 4.2)
    sunFire.Rate         = 65
    sunFire.Speed        = NumberRange.new(3, 10)
    sunFire.SpreadAngle  = Vector2.new(360, 360)
    sunFire.RotSpeed     = NumberRange.new(-180, 180)
    sunFire.LightEmission = 1
    sunFire.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0,   0.0),
        NumberSequenceKeypoint.new(0.4, 0.15),
        NumberSequenceKeypoint.new(0.8, 0.55),
        NumberSequenceKeypoint.new(1,   1.0),
    }
    sunFire.Enabled = true

    -- Soft corona halo: bigger and phase-colored
    sunCorona = Instance.new("ParticleEmitter", sunOrb)
    sunCorona.Texture       = "rbxasset://textures/whiteCircle.png"
    sunCorona.Color         = SUN_ORB_CORONA_COLORS[chargePhase] or SUN_ORB_CORONA_COLORS[1]
    sunCorona.Size          = NumberSequence.new{
        NumberSequenceKeypoint.new(0,   6.0),
        NumberSequenceKeypoint.new(0.5, 9.0),
        NumberSequenceKeypoint.new(1,   0),
    }
    sunCorona.Lifetime      = NumberRange.new(2.2, 4.5)
    sunCorona.Rate          = 8
    sunCorona.Speed         = NumberRange.new(0, 2)
    sunCorona.SpreadAngle   = Vector2.new(360, 360)
    sunCorona.LightEmission = 0.6
    sunCorona.Transparency  = NumberSequence.new{
        NumberSequenceKeypoint.new(0,   0.88),
        NumberSequenceKeypoint.new(0.5, 0.72),
        NumberSequenceKeypoint.new(1,   1.0),
    }
    sunCorona.Enabled = true

    tw(sunOrb, CFG.sunSummonTime, {
        Size     = Vector3.new(CFG.sunSize, CFG.sunSize, CFG.sunSize),
        Position = hrp.Position + hrp.CFrame.LookVector * -CFG.behindDist + Vector3.new(0, 5, 0),
    }, Enum.EasingStyle.Back)

    if sunConn then sunConn:Disconnect() end
    sunConn = RunService.Heartbeat:Connect(function()
        if not sunOrb or not hrp or not hrp.Parent then return end
        if not toggles.sunOrb then return end
        local t      = tick()
        local center = hrp.Position + Vector3.new(0, CFG.orbitHeight, 0)
        local pulse  = 1 + math.sin(t * CFG.pulseSpeed * math.pi * 2) * ((CFG.pulseMax - CFG.pulseMin) * 0.5)
        local jitter = Vector3.new(
            math.noise(t * 3.7) * 0.55,
            math.noise(t * 4.1) * 0.7,
            math.noise(t * 3.3) * 0.55
        )
        local targetOffset
        if isCharging then
            local currentOrbitRadius = CFG.orbitRadius
            if chargePhase == 2 then currentOrbitRadius = CFG.orbitRadiusPhase2
            elseif chargePhase == 3 then currentOrbitRadius = CFG.orbitRadiusPhase3
            elseif chargePhase == 4 then currentOrbitRadius = CFG.orbitRadiusPhase4
            elseif chargePhase == 5 then currentOrbitRadius = CFG.orbitRadiusPhase5
            end

            local currentMajor = currentOrbitRadius
            local currentMinor = currentMajor * math.sqrt(1 - CFG.orbitEccentricity^2)
            local speedMult = (chargePhase == 5 and 1.0) or (chargePhase == 4 and 6.5) or (chargePhase == 3 and 3.85) or (chargePhase == 2 and 2.1) or 1
            local orbitSpeed = CFG.orbitSpeed * speedMult
            local angle = t * orbitSpeed

            local localX = currentMajor * math.cos(angle)
            local localZ = currentMinor * math.sin(angle)
            local yBob   = math.sin(t * CFG.orbitBobFreq * math.pi * 2) * CFG.orbitBobAmp

            local hrpCF      = hrp.CFrame
            local rightVec   = hrpCF.RightVector
            local forwardVec = hrpCF.LookVector
            local worldOffset = rightVec * localX + forwardVec * localZ

            targetOffset  = worldOffset + Vector3.new(0, yBob, 0) + jitter
            transitionStart   = t
            wasChargingLast   = true
        else
            local behind  = -hrp.CFrame.LookVector * CFG.behindDist
            local swayX   = math.sin(t * CFG.swayFreq) * CFG.swayAmp
            local swayZ   = math.cos(t * CFG.swayFreq * 0.8) * CFG.swayAmp * 0.6
            local bob     = math.sin(t * CFG.sunBobFreq * math.pi * 2) * CFG.sunBobAmp
            targetOffset  = behind + Vector3.new(swayX, 10 + bob, swayZ) + jitter
            if wasChargingLast then
                local alpha = math.clamp((t - transitionStart) / CFG.transitionTime, 0, 1)
                if alpha < 1 then
                    targetOffset = (sunOrb.Position - center):Lerp(targetOffset, alpha ^ 1.5)
                else
                    wasChargingLast = false
                end
            end
        end

        local targetPos = center + targetOffset
        sunOrb.Position = sunOrb.Position:Lerp(targetPos, 0.13)
        sunOrb.CFrame   = CFrame.lookAt(sunOrb.Position, center + Vector3.new(0, 2, 0))
            * CFrame.Angles(0, t * CFG.swayRotSpeed, math.sin(t * 1.8) * 0.1)
        sunOrb.Size     = sunOrb.Size:Lerp(Vector3.new(CFG.sunSize, CFG.sunSize, CFG.sunSize) * pulse, 0.07)
    end)
end

--// ANIMATION
local function loadAnim(humanoid, id, looped, priority)
    local a = Instance.new("Animation")
    a.AnimationId = id
    local t = humanoid:LoadAnimation(a)
    t.Looped   = looped or false
    t.Priority = priority or Enum.AnimationPriority.Action
    return t
end

local function playOnly(track, fade, speed)
    if not track then return end
    for _, t in pairs(tracks) do
        if t and t ~= track and t.IsPlaying then
            pcall(t.Stop, t, fade or 0.15)
        end
    end
    pcall(track.Play, track, fade or 0.1, 1, speed or 1)
end

--// DASH TRAIL — burst ball and all emitters use live chargePhase at time of dash
local function makeDashTrail(hrp)
    -- Snapshot the current phase at the moment of the dash
    local phase = orbPhase
    local cols  = DASH_BALL_COLORS[phase] or DASH_BALL_COLORS[1]

    -- Main wide motion trail
    local trail = Instance.new("Trail")
    local a0 = Instance.new("Attachment", hrp); a0.Position = Vector3.new(0,  5, 0)
    local a1 = Instance.new("Attachment", hrp); a1.Position = Vector3.new(0, -5, 0)
    trail.Attachment0   = a0
    trail.Attachment1   = a1
    trail.Lifetime      = 0.18
    trail.MinLength     = 0.04
    trail.Transparency  = NumberSequence.new{ NumberSequenceKeypoint.new(0, 0.0), NumberSequenceKeypoint.new(0.4, 0.2), NumberSequenceKeypoint.new(1, 1) }
    trail.WidthScale    = NumberSequence.new{ NumberSequenceKeypoint.new(0, 9), NumberSequenceKeypoint.new(0.5, 5), NumberSequenceKeypoint.new(1, 0) }
    trail.Color         = DASH_TRAIL_COLORS[phase] or DASH_TRAIL_COLORS[1]
    trail.LightEmission = 1.0
    trail.Parent        = hrp
    Debris:AddItem(trail, 0.5); Debris:AddItem(a0, 0.5); Debris:AddItem(a1, 0.5)

    -- Inner sharp core trail
    local coreTrail = Instance.new("Trail")
    local c0 = Instance.new("Attachment", hrp); c0.Position = Vector3.new(0, 1, 0)
    local c1 = Instance.new("Attachment", hrp); c1.Position = Vector3.new(0,-1, 0)
    coreTrail.Attachment0   = c0
    coreTrail.Attachment1   = c1
    coreTrail.Lifetime      = 0.10
    coreTrail.MinLength     = 0.02
    coreTrail.Transparency  = NumberSequence.new{ NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1) }
    coreTrail.WidthScale    = NumberSequence.new{ NumberSequenceKeypoint.new(0, 2.5), NumberSequenceKeypoint.new(1, 0) }
    coreTrail.Color         = ColorSequence.new(Color3.fromRGB(255,255,255))
    coreTrail.LightEmission = 1.0
    coreTrail.Parent        = hrp
    Debris:AddItem(coreTrail, 0.4); Debris:AddItem(c0, 0.4); Debris:AddItem(c1, 0.4)

    -- Burst ball — phase-colored, emitted from both hands
    local char = lp.Character
    local handNames = {"RightHand", "LeftHand", "Right Arm", "Left Arm"}
    local hands = {}
    if char then
        for _, n in ipairs(handNames) do
            local h = char:FindFirstChild(n)
            if h and not (n == "Right Arm" and #hands >= 1) and not (n == "Left Arm" and #hands >= 2) then
                hands[#hands + 1] = h
            end
        end
    end
    -- fallback: emit from hrp if no hands found
    if #hands == 0 then hands = {hrp} end

    -- Shared size params
    local ballSizeBase = 1.2 + phase * 0.35
    local ballSizePeak = 2.5 + phase * 0.55

    for _, handPart in ipairs(hands) do
        -- Use a temporary Part anchored at the hand so destroying the
        -- attachment later doesn't kill mid-flight particles
        local ghost = Instance.new("Part")
        ghost.Anchored   = true
        ghost.CanCollide = false
        ghost.Transparency = 1
        ghost.Size       = Vector3.new(0.1, 0.1, 0.1)
        ghost.CFrame     = handPart.CFrame
        ghost.Parent     = workspace
        Debris:AddItem(ghost, 1.5)  -- outlives all particle lifetimes

        local ballAtt = Instance.new("Attachment", ghost)

        local ball = Instance.new("ParticleEmitter", ballAtt)
        ball.Texture       = "rbxasset://textures/particles/fire_main.dds"
        ball.Color         = ColorSequence.new{
            ColorSequenceKeypoint.new(0,   cols[1]),
            ColorSequenceKeypoint.new(0.5, cols[2]),
            ColorSequenceKeypoint.new(1,   cols[3]),
        }
        ball.Size          = NumberSequence.new{
            NumberSequenceKeypoint.new(0,   ballSizeBase),
            NumberSequenceKeypoint.new(0.2, ballSizePeak),
            NumberSequenceKeypoint.new(0.6, ballSizeBase * 1.1),
            NumberSequenceKeypoint.new(1,   0),
        }
        ball.Lifetime      = NumberRange.new(0.35, 0.75)
        ball.Rate          = 0
        ball.Speed         = NumberRange.new(10 + phase * 3, 30 + phase * 6)
        ball.SpreadAngle   = Vector2.new(360, 360)
        ball.RotSpeed      = NumberRange.new(-300, 300)
        ball.LightEmission = 1
        ball.Transparency  = NumberSequence.new{
            NumberSequenceKeypoint.new(0,   0.0),
            NumberSequenceKeypoint.new(0.3, 0.05),
            NumberSequenceKeypoint.new(1,   1.0),
        }
        ball:Emit(40 + phase * 15)

        local streaks = Instance.new("ParticleEmitter", ballAtt)
        streaks.Texture       = "rbxassetid://6101261905"
        streaks.Color         = ColorSequence.new{
            ColorSequenceKeypoint.new(0, cols[1]),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255)),
        }
        streaks.Size          = NumberSequence.new{
            NumberSequenceKeypoint.new(0,   0.12 + phase * 0.03),
            NumberSequenceKeypoint.new(0.5, 0.28 + phase * 0.06),
            NumberSequenceKeypoint.new(1,   0),
        }
        streaks.Lifetime      = NumberRange.new(0.10, 0.28)
        streaks.Rate          = 0
        streaks.Speed         = NumberRange.new(20 + phase * 6, 55 + phase * 12)
        streaks.SpreadAngle   = Vector2.new(35, 35)
        streaks.LightEmission = 1
        streaks.Transparency  = NumberSequence.new{ NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1) }
        streaks:Emit(20 + phase * 8)
    end

    -- Shockwave ring at hrp center
    local ringAtt = Instance.new("Attachment", hrp)
    ringAtt.Position = Vector3.new(0, 0, 0)
    local ring = Instance.new("ParticleEmitter", ringAtt)
    ring.Texture      = "rbxasset://textures/whiteCircle.png"
    ring.Color        = ColorSequence.new(cols[1])
    ring.Size         = NumberSequence.new{
        NumberSequenceKeypoint.new(0,   0),
        NumberSequenceKeypoint.new(0.3, 6 + phase * 2),
        NumberSequenceKeypoint.new(1,   10 + phase * 3),
    }
    ring.Lifetime     = NumberRange.new(0.22, 0.32)
    ring.Rate         = 0
    ring.Speed        = NumberRange.new(0)
    ring.LightEmission = 1
    ring.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0,   1),
        NumberSequenceKeypoint.new(0.2, 0.15),
        NumberSequenceKeypoint.new(0.7, 0.55),
