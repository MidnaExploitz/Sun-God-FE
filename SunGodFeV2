local chargeSoundThread
local function getChargeSoundPitch()
    if chargePhase == 5 then return 0.55
    elseif chargePhase == 4 then return 0.50
    elseif chargePhase == 3 then return 0.70
    else return 1.0 end
end

local function chargeSoundLoop()
    if chargeSoundThread then task.cancel(chargeSoundThread) end
    chargeSoundThread = task.spawn(function()
        while isCharging do
            if chargeSoundA then
                chargeSoundA.PlaybackSpeed = getChargeSoundPitch()
                chargeSoundA:Play()
            end
            task.wait(CFG.chargeLength - CFG.crossfade)
            if not isCharging then break end
            if chargeSoundB then
                chargeSoundB.PlaybackSpeed = getChargeSoundPitch()
                chargeSoundB:Play()
            end
            task.wait(CFG.chargeLength - CFG.crossfade)
        end
    end)
end

