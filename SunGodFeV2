local function setupCharge(hrp)
    if chargeAtt then chargeAtt:Destroy() end
    chargeAtt = Instance.new("Attachment", hrp)
    chargeAtt.Position = Vector3.new(0, 2, 0)

    chargeSoundA         = Instance.new("Sound", hrp)
    chargeSoundA.SoundId = CFG.chargeLoopSound
    chargeSoundA.Looped  = false
    chargeSoundA.Volume  = 0
    chargeSoundB         = chargeSoundA:Clone()
    chargeSoundB.Parent  = hrp

    local function makeParticle(tex, col, sizePts, life, rate, speed)
        local pe = Instance.new("ParticleEmitter", chargeAtt)
        pe.Texture       = tex
        pe.Color         = col
        pe.Size          = NumberSequence.new(sizePts)
        pe.Lifetime      = NumberRange.new(table.unpack(life))
        pe.Rate          = rate
        pe.Speed         = NumberRange.new(table.unpack(speed))
        pe.SpreadAngle   = Vector2.new(360, 360)
        pe.LightEmission = 1
        pe.Transparency  = NumberSequence.new{ NumberSequenceKeypoint.new(0, 0), NumberSequenceKeypoint.new(1, 1) }
        return pe
    end

    chargeParticles = makeParticle(
        "rbxasset://textures/particles/sparkles.png",
        ColorSequence.new(Color3.fromRGB(255,255,0)),
        { NumberSequenceKeypoint.new(0,0.5), NumberSequenceKeypoint.new(0.5,1.6), NumberSequenceKeypoint.new(1,0) },
        {0.5, 1.6}, 0, {8,16}
    )
    chargeParticles.RotSpeed = NumberRange.new(100, 320)
    chargeParticles.ZOffset  = 2

    local function makeRing(col, sizePts, life, transP)
        local pe = Instance.new("ParticleEmitter", chargeAtt)
        pe.Texture      = "rbxasset://textures/whiteCircle.png"
        pe.Color        = ColorSequence.new(col)
        pe.Size         = NumberSequence.new(sizePts)
        pe.Lifetime     = NumberRange.new(life)
        pe.Rate         = 0
        pe.Transparency = NumberSequence.new(transP)
        pe.Orientation  = Enum.ParticleOrientation.FacingCamera
        pe.LightEmission = 1
        pe.Speed        = NumberRange.new(0)
        return pe
    end

    ringParticles = makeRing(
        Color3.fromRGB(255,255,255),
        { NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(0.2,5), NumberSequenceKeypoint.new(1,10) },
        1.0,
        { NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(0.2,0), NumberSequenceKeypoint.new(1,1) }
    )
    yellowRingParticles = makeRing(
        Color3.fromRGB(255,255,0),
        { NumberSequenceKeypoint.new(0,0), NumberSequenceKeypoint.new(0.3,4), NumberSequenceKeypoint.new(1,8) },
        0.8,
        { NumberSequenceKeypoint.new(0,1), NumberSequenceKeypoint.new(0.3,0.2), NumberSequenceKeypoint.new(1,1) }
    )

    centralGlow = Instance.new("ParticleEmitter", chargeAtt)
    centralGlow.Texture  = "rbxasset://textures/whiteCircle.png"
    centralGlow.Color    = ColorSequence.new{ ColorSequenceKeypoint.new(0,Color3.fromRGB(255,255,0)), ColorSequenceKeypoint.new(1,Color3.fromRGB(255,200,0)) }
    centralGlow.Size     = NumberSequence.new{ NumberSequenceKeypoint.new(0,2), NumberSequenceKeypoint.new(0.5,2.6), NumberSequenceKeypoint.new(1,2) }
    centralGlow.Lifetime = NumberRange.new(0.5)
    centralGlow.Rate     = 0
    centralGlow.LightEmission = 1
    centralGlow.Speed    = NumberRange.new(0)
    centralGlow.Transparency = NumberSequence.new{ NumberSequenceKeypoint.new(0,0.5), NumberSequenceKeypoint.new(1,0.5) }

    for _, b in ipairs(lightningBeams) do
        if b.beam then b.beam:Destroy() end
        if b.a0 then b.a0:Destroy() end
        if b.a1 then b.a1:Destroy() end
    end
    lightningBeams = {}

    for i = 1, 8 do
        table.insert(lightningBeams, makeBolt(hrp))
