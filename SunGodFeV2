--// DASH
local function doDash(hrp, humanoid)
    if dashCooldown or dashCount < 1 then return false end

    local consume = 1
    if isCharging then
        if chargePhase == 3 then consume = 2
        elseif chargePhase == 4 then consume = 3
        elseif chargePhase == 5 then consume = 4 end
    end
    if dashCount < consume then return false end

    dashCooldown = true
    dashCount -= consume
    updateDashBar()
    isDashing = true

    if tracks.dash then tracks.dash:Play(0.05, 1, 1.3) end
    humanoid.AutoRotate = false

    local currentDashForce = CFG.dashForce
    local currentDashTime  = CFG.dashTime
    if isCharging then
        if chargePhase == 2 then
            currentDashForce = CFG.dashForcePhase2; currentDashTime = CFG.dashTimePhase2
        elseif chargePhase == 3 then
            currentDashForce = CFG.dashForcePhase3; currentDashTime = CFG.dashTimePhase3
        elseif chargePhase == 4 then
            currentDashForce = CFG.dashForcePhase4; currentDashTime = CFG.dashTimePhase4
        elseif chargePhase == 5 then
            currentDashForce = CFG.dashForcePhase5; currentDashTime = CFG.dashTimePhase5
        end
    end

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = hrp.CFrame.LookVector * currentDashForce + Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
    bv.Parent   = hrp
    Debris:AddItem(bv, currentDashTime)

    if toggles.dashTrail then makeDashTrail(hrp) end

    local dashPitch = 1.0
    if isCharging then
        if chargePhase == 2 then dashPitch = 0.9
        elseif chargePhase == 3 then dashPitch = 0.8
        elseif chargePhase == 4 then dashPitch = 0.65
        elseif chargePhase == 5 then dashPitch = 0.5 end
    end
    playSound(CFG.dashSound, hrp, 1, dashPitch)

    task.delay(currentDashTime, function()
        humanoid.AutoRotate = true
        isDashing = false
    end)

    local phaseCooldown = CFG.dashCooldown
    if isCharging then
        if chargePhase == 2 then phaseCooldown = CFG.dashCooldown * 1.3
        elseif chargePhase == 3 then phaseCooldown = CFG.dashCooldown * 1.7
        elseif chargePhase == 4 then phaseCooldown = CFG.dashCooldown * 2.2
        elseif chargePhase == 5 then phaseCooldown = CFG.dashCooldown * 3.0 end
    end
    task.delay(phaseCooldown, function() dashCooldown = false end)
    return true
end

