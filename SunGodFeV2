                updateOrbParticleColors(
                    { ColorSequenceKeypoint.new(0, Color3.fromRGB(255,120,255)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(200,50,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(140,0,255)) },
