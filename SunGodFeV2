    tw(stroke, 0.5, { Color = strokeCol })
    grad.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0,   cols[1]),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(
            math.floor((cols[1].R*255 + cols[2].R*255)/2),
            math.floor((cols[1].G*255 + cols[2].G*255)/2),
            math.floor((cols[1].B*255 + cols[2].B*255)/2)
        )),
        ColorSequenceKeypoint.new(1,   cols[2]),
    }
end

