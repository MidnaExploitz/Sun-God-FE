local function updateOrbParticleColors(fireColors, sparkColors, emberColors)
    if sunFire       then sunFire.Color       = ColorSequence.new(fireColors)  end
    if sunInnerSpark then sunInnerSpark.Color  = ColorSequence.new(sparkColors) end
    if sunEmbers     then sunEmbers.Color      = ColorSequence.new(emberColors) end
end

local function enterPhase2()
    fullPower = true
    chargePhase = 2
    fullPowerStartTime = tick()

    persistentSunColor  = Color3.fromRGB(255, 85, 0)
    persistentLightColor = Color3.fromRGB(255, 85, 0)

    if sunOrb then
        tw(sunOrb, 0.6, { Color = persistentSunColor })
        local light = sunOrb:FindFirstChildWhichIsA("PointLight")
        if light then tw(light, 0.6, { Color = persistentLightColor, Brightness = 6 }) end
        if sunFire then
            sunFire.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0,   Color3.fromRGB(255, 140, 50)),
                ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255, 100, 30)),
                ColorSequenceKeypoint.new(1,   Color3.fromRGB(200, 45,  0)),
            }
        end
        updateOrbParticleColors(
            { ColorSequenceKeypoint.new(0, Color3.fromRGB(255,140,50)), ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255,100,30)), ColorSequenceKeypoint.new(1, Color3.fromRGB(200,45,0)) },
            { ColorSequenceKeypoint.new(0, Color3.fromRGB(255,200,100)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,80,0)) },
            { ColorSequenceKeypoint.new(0, Color3.fromRGB(255,160,40)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(220,80,0)), ColorSequenceKeypoint.new(1, Color3.fromRGB(160,20,0)) }
        )
    end

    if tracks.charge and tracks.charge.IsPlaying then tracks.charge:Stop(0.12) end
    if tracks.fullCharge then tracks.fullCharge:Play(0.18, 1, 1.1) end

    screenFlash(255, 210, 0, 0.08, 0.7)

    if chargeSoundA then tw(chargeSoundA, 0.5, { Volume = 1.85 }) end
    if chargeSoundB then tw(chargeSoundB, 0.5, { Volume = 1.85 }) end

    if chargeParticles then
        chargeParticles:Emit(400)
        TweenService:Create(chargeParticles, TweenInfo.new(0.5), { Rate = 3400 }):Play()
    end
    if centralGlow then
        centralGlow:Emit(18)
        TweenService:Create(centralGlow, TweenInfo.new(0.5), { Rate = 32 }):Play()
    end
    if ringParticles then ringParticles:Emit(8) end
    if yellowRingParticles then yellowRingParticles:Emit(6) end

    -- Update existing bolts to phase 2 colors
    local cols2 = BOLT_COLORS[2]
    for _, b in ipairs(lightningBeams) do
        if b.beam then
            b.beam.Width0 = 0.95
            b.beam.Width1 = 0.28
            b.beam.LightEmission = 1.3
            b.beam.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, cols2[1]),
                ColorSequenceKeypoint.new(1, cols2[2]),
            }
        end
    end

    local char2 = lp.Character
    local hrp2  = char2 and char2:FindFirstChild("HumanoidRootPart")
    if hrp2 then
        for i = 1, 3 do
            local b = makeBolt(hrp2)
            if b.beam then
                b.beam.Width0 = 0.95
                b.beam.Width1 = 0.28
                b.beam.LightEmission = 1.3
            end
            table.insert(lightningBeams, b)
        end
    end

    updateSunGodTitle(chargePhase)
end

