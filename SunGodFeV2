    if centralGlow then
        centralGlow.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 220, 255)),
        }
        TweenService:Create(centralGlow, TweenInfo.new(0.8), { Rate = 2200 }):Play()
        centralGlow:Emit(350)
    end
    if ringParticles then ringParticles:Emit(200) end
    if yellowRingParticles then
        yellowRingParticles.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
        yellowRingParticles:Emit(160)
    end

    local cols5 = BOLT_COLORS[5]
    for _, b in ipairs(lightningBeams) do
        if b.beam then
            b.beam.Width0       = 4.1
            b.beam.Width1       = 1.25
            b.beam.LightEmission = 3.0
            b.beam.Transparency = NumberSequence.new(0.0)
            b.beam.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, cols5[1]),
                ColorSequenceKeypoint.new(1, cols5[2]),
            }
        end
    end

    local char5 = lp.Character
    local hrp5  = char5 and char5:FindFirstChild("HumanoidRootPart")
    if hrp5 then
        for i = 1, 18 do
            local b = makeBolt(hrp5)
            if b.beam then
                b.beam.Width0       = 4.7
                b.beam.Width1       = 1.4
                b.beam.LightEmission = 3.0
                b.beam.Transparency = NumberSequence.new(0.0)
            end
            table.insert(lightningBeams, b)
        end
    end

    if hrp5 and chargeBaseCF then
        if phase5FloatConn then phase5FloatConn:Disconnect() end

        local basePos    = chargeBaseCF.Position
        local baseRot    = chargeBaseCF - chargeBaseCF.Position
        local floatOrigin = basePos + Vector3.new(0, CFG.phase5FloatHeight, 0)

        local freqY  = 0.38
        local freqX  = 0.17
        local freqZ  = 0.23
        local ampY   = 1.6
        local ampXZ  = 1.2

        local phaseX = math.random() * math.pi * 2
        local phaseZ = math.random() * math.pi * 2

        local lastMoveTime  = 0
        local MOVE_INTERVAL = 0.85

        phase5FloatConn = RunService.Heartbeat:Connect(function()
            if not isCharging or chargePhase ~= 5 or not hrp5 or not hrp5.Parent then
                if phase5FloatConn then phase5FloatConn:Disconnect(); phase5FloatConn = nil end
                return
            end

            local t = tick()
            local driftX = math.sin(t * freqX + phaseX) * ampXZ
            local driftY = math.sin(t * freqY) * ampY
            local driftZ = math.sin(t * freqZ + phaseZ) * ampXZ

            local sineTarget = floatOrigin + Vector3.new(driftX, driftY, driftZ)

            if t - lastMoveTime > MOVE_INTERVAL then
                lastMoveTime    = t
                MOVE_INTERVAL   = 0.7 + math.random() * 0.8
                local ox = (math.random() - 0.5) * 0.6
                local oz = (math.random() - 0.5) * 0.6
                local newOrigin = floatOrigin + Vector3.new(ox, 0, oz)
                if (newOrigin - floatOrigin).Magnitude < 1.5 then
                    floatOrigin = newOrigin
                end
            end

            local newPos = hrp5.Position:Lerp(sineTarget, CFG.phase5FloatSpeed * 1.8)
            hrp5.CFrame  = CFrame.new(newPos) * baseRot
        end)
    end

    if phase5FlashThread then task.cancel(phase5FlashThread) end
    phase5FlashThread = task.spawn(function()
        while isCharging and chargePhase == 5 do
            local interval = 0.9 + math.random() * 1.6
            task.wait(interval)
            if not isCharging or chargePhase ~= 5 then break end
            screenFlash(255, 255, 255, 0.48 + math.random() * 0.32, 0.7 + math.random() * 0.5)
        end
    end)

    local charForEnd = lp.Character
    local hrpForEnd  = charForEnd and charForEnd:FindFirstChild("HumanoidRootPart")
    if hrpForEnd then
        task.delay(CFG.phase5Duration, function()
            if isCharging and chargePhase == 5 and hrpForEnd.Parent then
                toggleCharge(hrpForEnd)
            end
        end)
    end

    updateSunGodTitle(chargePhase)
end

local function resetEnhancements()
    -- Snapshot the phase reached so the sun orb keeps those colors after charge ends
    local lastPhase = chargePhase

    fullPower = false
    chargePhase = 1
    fullPowerStartTime = 0
    phase3StartTime = 0
    phase4StartTime = 0

    if phase4FlashThread then task.cancel(phase4FlashThread); phase4FlashThread = nil end
    if phase5FlashThread then task.cancel(phase5FlashThread); phase5FlashThread = nil end
    if phase5FloatConn   then phase5FloatConn:Disconnect();  phase5FloatConn   = nil end

    -- Keep the sun orb fire/corona/light at the last phase's colors so it
    -- doesn't snap back to plain yellow the moment charge is released.
    -- persistentSunColor and persistentLightColor were already set by the
    -- last enterPhaseX call, so we just re-apply them without overwriting.
    if sunFire   and SUN_ORB_FIRE_COLORS[lastPhase]   then sunFire.Color   = SUN_ORB_FIRE_COLORS[lastPhase]   end
    if sunCorona and SUN_ORB_CORONA_COLORS[lastPhase]  then sunCorona.Color = SUN_ORB_CORONA_COLORS[lastPhase]  end
    if sunOrb then
        tw(sunOrb, 0.6, { Color = persistentSunColor })
        local light = sunOrb:FindFirstChildWhichIsA("PointLight")
        if light then
            tw(light, 0.6, { Color = persistentLightColor })
        end
    end

    if tracks.fullCharge       and tracks.fullCharge.IsPlaying       then tracks.fullCharge:Stop(0.3)       end
    if tracks.ultraCharge      and tracks.ultraCharge.IsPlaying      then tracks.ultraCharge:Stop(0.3)      end
    if tracks.superUltraCharge and tracks.superUltraCharge.IsPlaying then tracks.superUltraCharge:Stop(0.3) end
    if tracks.divineAscension  and tracks.divineAscension.IsPlaying  then tracks.divineAscension:Stop(0.3)  end

    if chargeSoundA then chargeSoundA.Volume = 1; chargeSoundA.PlaybackSpeed = 1 end
    if chargeSoundB then chargeSoundB.Volume = 1; chargeSoundB.PlaybackSpeed = 1 end

    for _, b in ipairs(lightningBeams) do
        if b.beam then b.beam:Destroy() end
        if b.a0   then b.a0:Destroy()  end
        if b.a1   then b.a1:Destroy()  end
    end
    lightningBeams = {}

    updateSunGodTitle(1)
end

