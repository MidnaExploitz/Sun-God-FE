                )
            else
                updateOrbParticleColors(
                    { ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,120)), ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,180,30)), ColorSequenceKeypoint.new(1, Color3.fromRGB(200,60,0)) },
                    { ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,200)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,200,50)) },
