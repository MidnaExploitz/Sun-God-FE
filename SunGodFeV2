        end)
    end

    task.delay(stats.cooldown, function() punchCooldown = false end)
end

--// FLICKER + RING LOOPS
local flickerThread
local function startFlicker()
    if flickerThread then task.cancel(flickerThread) end
    flickerThread = task.spawn(function()
        while isCharging do
            local flickerRate = (chargePhase == 4) and 0.018 or (chargePhase == 3 and 0.035) or 0.06
            local spreadRange = (chargePhase == 4) and 14 or 8
            for _, b in ipairs(lightningBeams) do
                if b.beam then
                    local transpMin = (chargePhase == 4) and 0 or 10
                    local transpMax = (chargePhase == 4) and 15 or 40
                    b.beam.Transparency = NumberSequence.new(math.random(transpMin, transpMax) / 100)
                    b.a1.Position = Vector3.new(
                        math.random(-spreadRange, spreadRange),
                        math.random(-6, 12),
                        math.random(-spreadRange, spreadRange)
                    )
                    b.beam.CurveSize0 = math.random(-6, 6)
                    b.beam.CurveSize1 = math.random(-6, 6)
                end
            end
            task.wait(flickerRate)
        end
    end)
end

local ringLoop
ringLoop = function(emitter, interval)
    task.spawn(function()
        while isCharging and emitter do
            emitter:Emit(1)
            task.wait(interval or 1.8)
        end
    end)
end

--// CHARGE SETUP
local function setupCharge(hrp)
    if chargeAtt then chargeAtt:Destroy() end
    chargeAtt = Instance.new("Attachment", hrp)
    chargeAtt.Position = Vector3.new(0, 2, 0)

    chargeSoundA         = Instance.new("Sound", hrp)
    chargeSoundA.SoundId = CFG.chargeLoopSound
    chargeSoundA.Looped  = false
    chargeSoundA.Volume  = 0
    chargeSoundB         = chargeSoundA:Clone()
    chargeSoundB.Parent  = hrp

    local function makeParticle(tex, col, sizePts, life, rate, speed)
        local pe = Instance.new("ParticleEmitter", chargeAtt)
        pe.Texture       = tex
        pe.Color         = col
        pe.Size          = NumberSequence.new(sizePts)
        pe.Lifetime      = NumberRange.new(table.unpack(life))
        pe.Rate          = rate
        pe.Speed         = NumberRange.new(table.unpack(speed))
