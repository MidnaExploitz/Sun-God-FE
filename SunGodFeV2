local function getPunchPitch()
    if not isCharging then return 1.2 end
    if chargePhase == 2 then return 1.1
    elseif chargePhase == 3 then return 0.9
    elseif chargePhase == 4 then return 0.75
    elseif chargePhase == 5 then return 0.6
    end
    return 1.2
end

local function getPunchSpeed()
    if not isCharging then return 0.35 end
    if chargePhase == 2 then return 0.30
    elseif chargePhase == 3 then return 0.25
    elseif chargePhase == 4 then return 0.20
    elseif chargePhase == 5 then return 0.15
    end
    return 0.35
end

--// DASH + PUNCH (fixed flame colors, pitch, and per-phase speed)
local function doDash(hrp, humanoid)
    if dashCooldown or dashCount < 1 then return false end

    local consume = 1
    if isCharging then
        if chargePhase == 3 then consume = 2
        elseif chargePhase == 5 then consume = 3 end
    end
    if dashCount < consume then return false end

    dashCooldown = true
    dashCount -= consume
    updateDashBar()
    isDashing = true

    if tracks.dash then tracks.dash:Play(0.05, 1, 1.3) end
    humanoid.AutoRotate = false

    local currentDashForce = CFG.dashForce
    local currentDashTime = CFG.dashTime
    if isCharging then
        if chargePhase == 2 then
            currentDashForce = CFG.dashForcePhase2
            currentDashTime = CFG.dashTimePhase2
        elseif chargePhase == 3 then
            currentDashForce = CFG.dashForcePhase3
            currentDashTime = CFG.dashTimePhase3
        elseif chargePhase == 4 then
            currentDashForce = CFG.dashForcePhase4
            currentDashTime = CFG.dashTimePhase4
        elseif chargePhase == 5 then
            currentDashForce = CFG.dashForcePhase5
            currentDashTime = CFG.dashTimePhase5
        end
    end

    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = hrp.CFrame.LookVector * currentDashForce + Vector3.new(0, hrp.AssemblyLinearVelocity.Y, 0)
    bv.Parent   = hrp
    Debris:AddItem(bv, currentDashTime)

    if toggles.dashTrail then makeDashTrail(hrp) end

    local dashPitch = 1.0
    if isCharging then
        if chargePhase == 2 then dashPitch = 0.9
        elseif chargePhase == 3 then dashPitch = 0.8
        elseif chargePhase == 4 then dashPitch = 0.65
        elseif chargePhase == 5 then dashPitch = 0.5
        end
    end
    playSound(CFG.dashSound, hrp, 1, dashPitch)

    task.delay(currentDashTime, function()
        humanoid.AutoRotate = true
        isDashing = false
    end)
    task.delay(CFG.dashCooldown, function() dashCooldown = false end)
    return true
end

local function doPunch(character)
    if punchCooldown then return end
    punchCooldown = true

    local hand = character:FindFirstChild("RightHand") or character:FindFirstChild("Right Arm")

    -- FIXED: per-phase punch animation speed
    if tracks.punch then tracks.punch:Play(0.15, 1, getPunchSpeed()) end

    -- FIXED: per-phase punch sound pitch
    local punchPitch = getPunchPitch()
    playSound(CFG.punchSound, hand or character, 0.85, punchPitch)

    -- FIXED: flame balls now guaranteed correct colors per phase
    if hand then
        local pe = Instance.new("ParticleEmitter", hand)
        pe.Texture = "rbxasset://textures/whiteCircle.png"
        pe.Color = getPunchFlameColor()

        pe.Size         = NumberSequence.new{ NumberSequenceKeypoint.new(0, 0.5), NumberSequenceKeypoint.new(0.5, 1.4), NumberSequenceKeypoint.new(1, 0) }
        pe.Lifetime     = NumberRange.new(0.35, 0.75)
        pe.Rate         = 450
