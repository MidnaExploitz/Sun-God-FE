--// SUN ORB — updateSunOrbPhase now also updates the corona emitter color
local function updateSunOrbPhase(phase)
    if not sunOrb then return end
    local fireCol   = SUN_ORB_FIRE_COLORS[phase]   or SUN_ORB_FIRE_COLORS[1]
    local coronaCol = SUN_ORB_CORONA_COLORS[phase]  or SUN_ORB_CORONA_COLORS[1]

    if sunFire   then sunFire.Color   = fireCol   end
    if sunCorona then sunCorona.Color = coronaCol end

    tw(sunOrb, 0.6, { Color = persistentSunColor })
    local light = sunOrb:FindFirstChildWhichIsA("PointLight")
    if light then
        local brightness = (phase == 5 and 10) or (phase == 4 and 7) or (phase == 3 and 5.5) or 4.5
        tw(light, 0.6, { Color = persistentLightColor, Brightness = brightness })
    end
end

--// PHASE TRANSITIONS
local function enterPhase2()
    fullPower = true
    chargePhase = 2
    orbPhase = 2
    fullPowerStartTime = tick()

    persistentSunColor  = Color3.fromRGB(255, 85, 0)
    persistentLightColor = Color3.fromRGB(255, 85, 0)
    updateSunOrbPhase(2)

    if tracks.charge and tracks.charge.IsPlaying then tracks.charge:Stop(0.12) end
    if tracks.fullCharge then tracks.fullCharge:Play(0.18, 1, 1.1) end

    screenFlash(255, 210, 0, 0.08, 0.7)

    if chargeSoundA then tw(chargeSoundA, 0.5, { Volume = 1.85 }) end
    if chargeSoundB then tw(chargeSoundB, 0.5, { Volume = 1.85 }) end

    if chargeParticles then
        chargeParticles:Emit(400)
        chargeParticles.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0,   Color3.fromRGB(255, 200,  80)),
            ColorSequenceKeypoint.new(0.4, Color3.fromRGB(255, 120,  20)),
            ColorSequenceKeypoint.new(1,   Color3.fromRGB(200,  50,   0)),
        }
