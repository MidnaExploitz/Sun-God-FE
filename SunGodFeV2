-- Griefer input connections (always listening, gated by gState.active)
UserInputService.InputBegan:Connect(function(input, gp)
    if gp or not gState.active then return end
    local char = lp.Character
    if not char then return end

    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if gIsEmoting then return end
        task.spawn(function()
            gDoAttack(char)
        end)
    elseif input.KeyCode == Enum.KeyCode.B then
        if gIsEmoting then return end
        gStartBlock(char)
    elseif input.KeyCode == Enum.KeyCode.V then
        if gIsEmoting then
            gStopEmote(char)
        else
            gStartEmote(char)
        end
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        gState.shiftHeld = true
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if not gState.active then return end
    local char = lp.Character
    if input.KeyCode == Enum.KeyCode.B then
        gStopBlock(char)
    elseif input.KeyCode == Enum.KeyCode.LeftShift then
        gState.shiftHeld = false
    end
end)

