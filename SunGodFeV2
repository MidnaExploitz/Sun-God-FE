--// SCREEN FLASH
local flashFrame
local function ensureFlashFrame()
    if flashFrame and flashFrame.Parent then return end
    local sg = lp:FindFirstChild("PlayerGui"):FindFirstChild("CombatGUI")
    if not sg then return end
    flashFrame = Instance.new("Frame")
    flashFrame.Name = "PhaseFlash"
    flashFrame.Size = UDim2.new(1, 0, 1, 0)
    flashFrame.Position = UDim2.new(0, 0, 0, 0)
    flashFrame.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    flashFrame.BackgroundTransparency = 1
    flashFrame.BorderSizePixel = 0
    flashFrame.ZIndex = 100
    flashFrame.Parent = sg
end

local function screenFlash(r, g, b, peakTransp, duration)
    ensureFlashFrame()
    if not flashFrame then return end
    flashFrame.BackgroundColor3 = Color3.fromRGB(r, g, b)
    flashFrame.BackgroundTransparency = peakTransp
    TweenService:Create(flashFrame, TweenInfo.new(duration or 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        BackgroundTransparency = 1
    }):Play()
end

--// HELPERS
local function tw(obj, t, props, style, dir)
    TweenService:Create(obj, TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props):Play()
end

local function playSound(id, parent, volume, pitch)
    local s = Instance.new("Sound")
    s.SoundId  = id
    s.Volume   = volume or 1
    s.PlaybackSpeed = pitch or 1
    s.Parent   = parent
    s:Play()
    Debris:AddItem(s, 6)
    return s
end

local function disconnectAll(tbl)
    for k, c in pairs(tbl) do
        if c and c.Disconnect then c:Disconnect() end
        tbl[k] = nil
    end
end

--// LIGHTNING BOLT (uses current chargePhase for colors)
local function makeBolt(hrp)
    local cols = BOLT_COLORS[chargePhase] or BOLT_COLORS[1]
    local a0 = Instance.new("Attachment", hrp); a0.Position = Vector3.new(0, 2, 0)
    local a1 = Instance.new("Attachment", hrp)
    a1.Position = Vector3.new(math.random(-8, 8), math.random(-5, 10), math.random(-8, 8))
    local beam = Instance.new("Beam", hrp)
    beam.Attachment0   = a0
    beam.Attachment1   = a1
    beam.Color         = ColorSequence.new{
        ColorSequenceKeypoint.new(0, cols[1]),
        ColorSequenceKeypoint.new(1, cols[2]),
    }
    beam.Width0, beam.Width1 = 0.45, 0.10
    beam.Transparency  = NumberSequence.new(0.2)
    beam.LightEmission = 1
    beam.Texture       = "rbxassetid://7158722143"
    beam.TextureSpeed  = 5
    beam.TextureLength = 2
    beam.TextureMode   = Enum.TextureMode.Stretch
    beam.CurveSize0, beam.CurveSize1 = math.random(-3, 3), math.random(-3, 3)
    beam.FaceCamera    = true
    return { beam = beam, a0 = a0, a1 = a1 }
end

--// DYNAMIC SUN GOD TITLE (new 10x better version)
local function updateSunGodTitle(phase)
    if not titleTextLabel or not titleTextLabel.Parent then return end
    titleTextLabel.Text = PHASE_NAMES[phase] or PHASE_NAMES[1]

    local tc = PHASE_TITLE_COLOR[phase]  or PHASE_TITLE_COLOR[1]
    local sc = PHASE_STROKE_COLOR[phase] or PHASE_STROKE_COLOR[1]

    TweenService:Create(titleTextLabel, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
        TextColor3       = tc,
        TextStrokeColor3 = sc,
    }):Play()

    if titleRefs.stroke then
        TweenService:Create(titleRefs.stroke, TweenInfo.new(0.5, Enum.EasingStyle.Quad), {
            Color = PHASE_BORDER_COLOR[phase] or PHASE_BORDER_COLOR[1],
        }):Play()
    end
    if titleRefs.phaseLabel then
        titleRefs.phaseLabel.Text = PHASE_ROMAN[phase] or PHASE_ROMAN[1]
        TweenService:Create(titleRefs.phaseLabel, TweenInfo.new(0.5), { TextColor3 = tc }):Play()
    end
    if titleRefs.shimmer then
        TweenService:Create(titleRefs.shimmer, TweenInfo.new(0.5), {
            BackgroundColor3 = PHASE_SHIMMER_COLOR[phase] or PHASE_SHIMMER_COLOR[1],
        }):Play()
    end
end

